# Public site URL (used for canonical, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://ajnix.com

# WordPress headless blog API (leave empty in dev to use seed data fallback)
# Example: https://blog-admin.ajnix.com/wp-json
NEXT_PUBLIC_WP_API_URL=

# Plausible / Fathom analytics (optional, leave empty to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Waitlist counter source — minimal MVP uses local JSON file at /data/waitlist.json
# (no env var needed for the stub)
