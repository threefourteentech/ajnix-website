# Public site URL (used for canonical, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://ajnix.com

# WordPress headless blog API (leave empty in dev to use seed data fallback)
# Example: https://cms.ajnix.com/wp-json
NEXT_PUBLIC_WP_API_URL=

# Optional WP app password (basic auth) — only needed for private/draft access.
# Public posts do not require these.
WP_APP_USER=
WP_APP_PASSWORD=

# Plausible / Fathom analytics (optional, leave empty to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Waitlist: Loops.so integration (mailing list id comes from the Loops dashboard)
LOOPS_API_KEY=
LOOPS_PRO_WAITLIST_ID=

# reCAPTCHA v3 (score-based anti-spam on waitlist form)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# SMTP (contact form notifications). Leave SMTP_HOST empty to skip sending.
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE=true for port 465 (implicit TLS), false otherwise
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Ajnix <noreply@ajnix.com>"
CONTACT_TO=eric@stamant.me
